# ChatForge Environment Configuration

# LLM Provider Configuration
LLM_PROVIDER=openai
LLM_MODEL_NAME=gpt-4o-mini
LLM_TEMPERATURE=0.0

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Configuration (if using provider=anthropic)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# AWS Bedrock Configuration (if using provider=bedrock)
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1

# Agent Configuration
AGENT_MAX_ITERATIONS=10
AGENT_CONVERSATION_TIMEOUT_MINUTES=30

# Storage Configuration
STORAGE_CLEANUP_ENABLED=true
STORAGE_CACHE_CLEANUP_INTERVAL_SECONDS=900
STORAGE_ADAPTER_CLEANUP_INTERVAL_SECONDS=600
